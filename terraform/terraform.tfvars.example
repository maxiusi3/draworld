# Terraform 变量值示例文件
# 复制为 terraform.tfvars 并填入实际值

# 阿里云区域
region = "cn-hangzhou"

# FC 服务名称
service_name = "tonghua-world-svc"

# 通义千问 API 密钥
tongyi_api_key = "your-dashscope-api-key-here"

# OSS 存储桶名称（需要全局唯一）
oss_bucket_upload = "draworld2025"
oss_bucket_static = "draworld2"

# Tablestore 实例名称
tablestore_instance = "i01wvvv53p0q"

# OIDC 配置
oidc_issuer = "https://draworld.authing.cn/oidc"
oidc_jwks   = "https://draworld.authing.cn/oidc/.well-known/jwks.json"
oidc_aud    = "689adde75ecb97cd396860eb"

# STS 角色 ARN
assume_role_arn = "acs:ram::1950683455496289:role/upload"
